# Copy these into Vercel → Project → Settings → Environment Variables.
# Do NOT put real keys in this file — it is committed. Real values go in .env.local (gitignored) or the Vercel dashboard.

# Required — free key from console.groq.com
GROQ_API_KEY=

# Recommended
GROQ_MODEL=llama-3.3-70b-versatile

# Optional — OpenAI fallback (used only if no Groq key)
OPENAI_API_KEY=

# Required for cloud persistence AND accounts — Neon Postgres connection string
DATABASE_URL=

# Required for accounts — a long random string to sign login sessions
# Generate with:  openssl rand -hex 32
AUTH_SECRET=
