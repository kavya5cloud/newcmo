# Copy these into Vercel → Project → Settings → Environment Variables.

# Canonical public URL (set on Vercel to your primary domain). Makes OAuth redirect
# URIs deterministic so they match what you register in Google Cloud.
APP_URL=https://www.trypopulr.in
# Do NOT put real keys in this file — it is committed. Real values go in .env.local (gitignored) or the Vercel dashboard.

# Recommended primary — free key from aistudio.google.com/apikey. Google's free tier is
# generous and accurate, so it isn't starved by Groq's small 70b daily cap. When set, it's
# used first, with Groq as automatic fallback. Default model gemini-2.5-flash → gemini-2.0-flash.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Required (fallback / or use alone) — free key from console.groq.com
GROQ_API_KEY=

# Recommended — lead model. Default is llama-3.3-70b-versatile (most accurate); the app
# auto-falls back to llama-3.1-8b-instant, then llama-4-scout, then compound-mini on rate
# limits/quota so a request never fails. Set to a smaller model to cut quota burn.
GROQ_MODEL=llama-3.3-70b-versatile

# Optional AI-quality tuning:
#   LLM_TEMPERATURE   lower = more grounded/consistent answers + more reliable JSON (default 0.4)
#   MAX_OUTPUT_TOKENS higher = longer deliverables without truncation (default 1024)
LLM_TEMPERATURE=0.4
MAX_OUTPUT_TOKENS=1024

# Intelligence dataset versioning — bump when the recommendation prompt/shape changes
# so recommendation rows stay comparable within a version (see docs/intelligence.md).
PROMPT_VERSION=p1

# Optional — cap on generated tokens per request (default 512). Raise to 768 only if
# a CMO section is getting truncated. Lower = less quota burn.
MAX_OUTPUT_TOKENS=512

# Optional — caching (needs DATABASE_URL). Repeated analyses of the same site+prompt
# are served from Neon instead of re-calling the LLM, and page scrapes are reused when
# the HTML is unchanged. Defaults shown; all in milliseconds.
ANALYSIS_CACHE_TTL_MS=600000   # 10 min — fresh-hit window for cached AI analyses
ANALYSIS_STALE_MS=86400000     # 24 h — how stale a cached analysis may be when ALL providers fail
SITE_CACHE_TTL_MS=600000       # 10 min — reuse an extracted site summary without re-fetching
# Bump CACHE_VERSION (e.g. v1 → v2) whenever the prompt template changes, so old cached
# analyses are invalidated instead of being served after the change.
CACHE_VERSION=v1

# Optional — OpenAI fallback (used only if no Groq key)
OPENAI_API_KEY=

# Required for cloud persistence AND accounts — Neon Postgres connection string
DATABASE_URL=

# Required for accounts — a long random string to sign login sessions
# Generate with:  openssl rand -hex 32
AUTH_SECRET=

# Optional — Google Search Console integration (real analytics for your own sites)
# From Google Cloud Console → APIs & Services → Credentials → OAuth client (Web)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional — Web push notifications ("best time to publish" reminders)
# Generate with:  node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@cosmos.ai
# Protects the reminder cron endpoint (Vercel sets this automatically for its crons)
CRON_SECRET=

# Optional — social login. Google reuses GOOGLE_CLIENT_ID/SECRET above.
# Add the redirect URI  <your-domain>/api/auth/google/callback  in Google Cloud.
# Facebook (Meta Developers app) and X (X Developer app) are optional extras:
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
